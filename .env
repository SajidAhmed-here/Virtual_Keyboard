# Virtual Keyboard Configuration
# Edit these values to tune behaviour without touching code.

# Camera
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720

# Hand detection
HAND_CONFIDENCE_THRESHOLD=0.65   # lower = detects hand more easily
SMOOTHING_ALPHA=0.55              # lower = smoother but more lag

# Click gesture
# 0.07 = comfortable pinch distance for most people at ~60-80 cm from camera
# Raise to 0.09 if pinch still isn't registering
# Lower to 0.05 if you get too many false clicks
CLICK_THRESHOLD=0.07

# Wave gesture
WAVE_THRESHOLD=150
WAVE_WINDOW_SECONDS=2.0

# Keyboard UI
KEYBOARD_WIDTH_RATIO=0.88
KEYBOARD_HEIGHT=290
DARK_THEME=True
# Transparency: 0.4 = very see-through, 0.7 = mostly solid
KB_ALPHA=0.55

# Performance
FPS_LIMIT=60
